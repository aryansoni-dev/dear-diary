{
  "expo": {
    "name": "DearDiary",
    "slug": "dear-diary",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "deardiary",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "buildNumber": "4",
      "supportsTablet": true
    },
    "android": {
      "allowBackup": false,
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "icon": "./assets/images/icon.png",
      "package": "com.aryan.deardiary",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#FFDDE8",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F4EFFA",
          "dark": {
            "image": "./assets/images/icon.png",
            "backgroundColor": "#1C1B1F"
          }
        }
      ],
      "@clerk/expo",
      "expo-notifications",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow DearDiary to use Face ID to protect your private journal."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0a55a7c-da6d-40f8-afb7-cd5399caa416"
      }
    },
    "owner": "aryansoni-dev"
  }
}
